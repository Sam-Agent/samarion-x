# =============================================
# Samrion.vip — Environment Variables Example
# =============================================
# Copy this file to .env.local and fill in values
# cp .env.example .env.local
#
# ⚠️  NEVER commit .env.local to git!
# ⚠️  Stripe/Alipay/Provider API Keys are configured in /admin/settings UI
# =============================================

# ---------------------
# Database
# ---------------------
DATABASE_URL="postgresql://username:password@localhost:5432/samrion_dev"
# For local dev with SQLite:
# DATABASE_URL="file:./dev.db"

# ---------------------
# NextAuth.js
# ---------------------
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32-output"
NEXTAUTH_URL="http://localhost:3333"

# ---------------------
# Encryption Key (for Provider Channel API Keys stored in DB)
# ---------------------
# Must be exactly 32 bytes (64 hex chars)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="replace-with-64-char-hex-string"

# ---------------------
# App Config
# ---------------------
NEXT_PUBLIC_APP_URL="http://localhost:3333"
NEXT_PUBLIC_APP_NAME="Samrion.vip"

# ---------------------
# Optional: Direct Env Fallbacks
# (prefer configuring via /admin/settings UI)
# ---------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
